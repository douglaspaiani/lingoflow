generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  name             String
  username         String   @unique
  email            String   @unique
  password         String
  role             String   @default("ALUNO") // ADMIN or ALUNO
  avatar           String?
  phone            String?
  coverPhoto       String?
  points           Int      @default(0)
  streak           Int      @default(0)
  level            Int      @default(1)
  xp               Int      @default(0)
  energy           Int      @default(5)
  theme            String   @default("dark")
  classRoomId      String?
  classRoom        ClassRoom? @relation(fields: [classRoomId], references: [id])
  
  completedLessons UserLesson[]
  
  following        Friendship[] @relation("following")
  followers        Friendship[] @relation("followers")
  conquistasDesbloqueadas ConquistaAluno[] @relation("conquistasDesbloqueadasAluno")
  recompensasBauTrilha RecompensaBauTrilhaAluno[] @relation("recompensasBauTrilhaAluno")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdClasses   ClassRoom[] @relation("adminClasses")
  professorSessoesJogo PlaygroundSessaoJogo[] @relation("professorSessoesJogo")
  alunoRespostasJogo PlaygroundRespostaJogo[] @relation("alunoRespostasJogo")
  resultadosJogosAluno ResultadoJogoAluno[] @relation("resultadosJogosAluno")
}

model RecompensaBauTrilhaAluno {
  id             String   @id @default(uuid())
  alunoId        String
  aluno          User     @relation("recompensasBauTrilhaAluno", fields: [alunoId], references: [id], onDelete: Cascade)
  numeroBau      Int
  tipo           TipoRecompensaBauTrilha
  valor          Int      @default(0)
  duracaoMinutos Int?
  expiraEm       DateTime?
  criadoEm       DateTime @default(now())

  @@unique([alunoId, numeroBau])
  @@index([alunoId, criadoEm])
  @@index([alunoId, tipo, expiraEm])
}

enum TipoRecompensaBauTrilha {
  XP_DOBRO_5_MIN
  XP_DOBRO_10_MIN
  XP_DOBRO_20_MIN
  ENERGIA_5
  ENERGIA_10
}

model ClassRoom {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique // Turma code generated by Admin
  level     Int      @default(1)
  
  adminId   String
  admin     User     @relation("adminClasses", fields: [adminId], references: [id])

  students  User[]
  sessoesJogo PlaygroundSessaoJogo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlaygroundJogo {
  id        String   @id @default(uuid())
  slug      String   @unique
  nome      String
  descricao String?
  ativo     Boolean  @default(true)

  fasesImagem PlaygroundFaseImagem[]
  sessoes     PlaygroundSessaoJogo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlaygroundFaseImagem {
  id              String   @id @default(uuid())
  jogoId          String
  jogo            PlaygroundJogo @relation(fields: [jogoId], references: [id], onDelete: Cascade)
  nivel           Int
  ordem           Int      @default(0)
  imagem          String   @db.MediumText
  traducaoCorreta String
  ativo           Boolean  @default(true)

  respostas PlaygroundRespostaJogo[]
  sessoesComFaseAtual PlaygroundSessaoJogo[] @relation("faseAtualSessaoJogo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jogoId, nivel])
}

model PlaygroundSessaoJogo {
  id          String   @id @default(uuid())
  jogoId      String
  jogo        PlaygroundJogo @relation(fields: [jogoId], references: [id])
  turmaId     String
  turma       ClassRoom @relation(fields: [turmaId], references: [id])
  professorId String
  professor   User     @relation("professorSessoesJogo", fields: [professorId], references: [id])
  faseAtualId String?
  faseAtual   PlaygroundFaseImagem? @relation("faseAtualSessaoJogo", fields: [faseAtualId], references: [id])
  nivelTurma  Int
  status      String   @default("EM_ANDAMENTO") // EM_ANDAMENTO | ENCERRADO
  iniciadaEm  DateTime @default(now())
  encerradaEm DateTime?

  respostas PlaygroundRespostaJogo[]

  @@index([turmaId, status])
}

model PlaygroundRespostaJogo {
  id        String   @id @default(uuid())
  sessaoId  String
  sessao    PlaygroundSessaoJogo @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  faseId    String
  fase      PlaygroundFaseImagem @relation(fields: [faseId], references: [id], onDelete: Cascade)
  alunoId   String
  aluno     User     @relation("alunoRespostasJogo", fields: [alunoId], references: [id], onDelete: Cascade)
  resposta  String
  correta   Boolean  @default(false)
  pontos    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([sessaoId, alunoId])
  @@unique([sessaoId, faseId, alunoId])
}

model Level {
  id          String   @id @default(uuid())
  title       String
  description String
  difficulty  Int
  lessons     Lesson[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id        String     @id @default(uuid())
  title     String
  levelId   String
  level     Level      @relation(fields: [levelId], references: [id])
  exercises Exercise[]
  
  userProgress UserLesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exercise {
  id        String   @id @default(uuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  type      String   // translate, select, match, reorder
  question  String
  answer    String
  options   String   // JSON stringified array for options
  pairs     String?  // JSON stringified for match exercises
  xp        Int      @default(10)
  
  createdAt DateTime @default(now())
}

model UserLesson {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model Friendship {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("following", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("followers", fields: [followingId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Conquista {
  id          String   @id @default(uuid())
  nome        String
  descricao   String
  cor         String   @default("#3B82F6")
  icone       String   @default("Trophy")
  ativa       Boolean  @default(true)
  requisitos  ConquistaRequisito[]
  desbloqueios ConquistaAluno[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConquistaRequisito {
  id          String                  @id @default(uuid())
  conquistaId String
  conquista   Conquista               @relation(fields: [conquistaId], references: [id], onDelete: Cascade)
  tipo        TipoRequisitoConquista
  valorMinimo Int                     @default(1)
  ordem       Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([conquistaId, ordem])
}

model ConquistaAluno {
  id             String    @id @default(uuid())
  conquistaId    String
  conquista      Conquista @relation(fields: [conquistaId], references: [id], onDelete: Cascade)
  alunoId        String
  aluno          User      @relation("conquistasDesbloqueadasAluno", fields: [alunoId], references: [id], onDelete: Cascade)
  desbloqueadaEm DateTime  @default(now())

  @@unique([conquistaId, alunoId])
  @@index([alunoId, desbloqueadaEm])
}

enum TipoRequisitoConquista {
  PONTOS_TOTAIS
  XP_TOTAL
  NIVEL_ATUAL
  OFENSIVA_DIAS
  LICOES_CONCLUIDAS
  SEGUINDO_TOTAL
  SEGUIDORES_TOTAL
  ACERTOS_TOTAIS
  RESPOSTAS_TOTAIS
  JOGOS_CONCLUIDOS
}

enum OrigemResultadoJogoAluno {
  APP_PRINCIPAL
  JOGO_EXTRA
}

model ResultadoJogoAluno {
  id                String                     @id @default(uuid())
  alunoId           String
  aluno             User                       @relation("resultadosJogosAluno", fields: [alunoId], references: [id], onDelete: Cascade)
  origem            OrigemResultadoJogoAluno
  jogo              String
  acertos           Int                        @default(0)
  erros             Int                        @default(0)
  percentualAcerto  Float                      @default(0)
  lessonId          String?
  sessaoJogoId      String?
  criadoEm          DateTime                   @default(now())
  atualizadoEm      DateTime                   @updatedAt

  @@index([alunoId, criadoEm])
  @@index([origem, criadoEm])
}
