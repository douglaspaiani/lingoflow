generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  name             String
  username         String   @unique
  email            String   @unique
  password         String
  role             String   @default("ALUNO") // ADMIN or ALUNO
  avatar           String?
  coverPhoto       String?
  points           Int      @default(0)
  streak           Int      @default(0)
  level            Int      @default(1)
  xp               Int      @default(0)
  energy           Int      @default(5)
  classRoomId      String?
  classRoom        ClassRoom? @relation(fields: [classRoomId], references: [id])
  
  completedLessons UserLesson[]
  
  following        Friendship[] @relation("following")
  followers        Friendship[] @relation("followers")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdClasses   ClassRoom[] @relation("adminClasses")
}

model ClassRoom {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique // Turma code generated by Admin
  
  adminId   String
  admin     User     @relation("adminClasses", fields: [adminId], references: [id])

  students  User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Level {
  id          String   @id @default(uuid())
  title       String
  description String
  difficulty  Int
  lessons     Lesson[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id        String     @id @default(uuid())
  title     String
  levelId   String
  level     Level      @relation(fields: [levelId], references: [id])
  exercises Exercise[]
  
  userProgress UserLesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exercise {
  id        String   @id @default(uuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  type      String   // translate, select, match, reorder
  question  String
  answer    String
  options   String   // JSON stringified array for options
  pairs     String?  // JSON stringified for match exercises
  xp        Int      @default(10)
  
  createdAt DateTime @default(now())
}

model UserLesson {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model Friendship {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("following", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("followers", fields: [followingId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}
